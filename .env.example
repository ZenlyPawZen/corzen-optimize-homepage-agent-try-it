# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for CORS / redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Beehiiv (set as Supabase Edge Function secrets, NOT here) ───────────────
# In Supabase dashboard → Edge Functions → Secrets, add:
#   BEEHIIV_API_KEY   your Beehiiv API key
#   BEEHIIV_PUB_ID    your Beehiiv publication ID

# ─── Supabase Storage bucket (manual setup, no env var) ─────────────────────
# In Supabase dashboard → Storage → Create bucket:
#   name: homepage-audit-screenshots
#   visibility: private
# The service role key bypasses RLS, so no extra policies are needed.
